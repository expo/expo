{
  "name": "expo-docs",
  "version": "55.0.0",
  "betaVersion": "56.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm generate-static-resources && next dev -p 3002 --webpack",
    "build": "pnpm copy-latest && NEXT_TELEMETRY_DISABLED=1 SENTRY_SUPPRESS_INSTRUMENTATION_FILE_WARNING=1 next build --webpack && pnpm generate-markdown-pages && pnpm check-markdown-pages && pnpm generate-llms",
    "export": "pnpm copy-latest && pnpm generate-static-resources production && pnpm export-prep && NEXT_TELEMETRY_DISABLED=1 SENTRY_SUPPRESS_INSTRUMENTATION_FILE_WARNING=1 next build --webpack && pnpm generate-markdown-pages && pnpm check-markdown-pages && pnpm generate-llms",
    "export-preview": "pnpm copy-latest && pnpm generate-static-resources preview && pnpm export-prep && NEXT_TELEMETRY_DISABLED=1 SENTRY_SUPPRESS_INSTRUMENTATION_FILE_WARNING=1 next build --webpack && pnpm generate-markdown-pages && pnpm check-markdown-pages && pnpm generate-llms",
    "export-prep": "node ./scripts/export-prep.js",
    "export-server": "wrangler pages dev --port 8000",
    "test:worker": "node --experimental-strip-types scripts/test-worker.ts",
    "format": "oxfmt --write .",
    "lint": "NODE_OPTIONS='--no-warnings' node scripts/lint.js --max-warnings 0",
    "lint-links": "remark -u validate-links ./pages",
    "lint-prose": ".vale/bin/vale --config='.vale.ini' --glob='!{pages/versions/latest,pages/versions/latest/**,pages/internal,pages/internal/**}' pages scenes README.md",
    "watch": "tsc --noEmit -w",
    "test": "pnpm generate-static-resources && node --experimental-strip-types --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "remove-version": "node --unhandled-rejections=strict ./scripts/remove-version.js",
    "copy-latest": "node ./scripts/copy-latest.js",
    "generate-llms": "node --experimental-strip-types ./scripts/generate-llms/index.js",
    "generate-markdown-pages": "node --experimental-strip-types ./scripts/generate-markdown-pages.ts",
    "check-markdown-pages": "node --experimental-strip-types ./scripts/check-markdown-pages.ts",
    "generate-static-resources": "node --unhandled-rejections=strict ./scripts/generate-static-resources.js",
    "append-last-modified-dates": "node --unhandled-rejections=strict ./scripts/append-dates.js",
    "schema-sync": "node --async-stack-traces --unhandled-rejections=strict ./scripts/schema-sync.js",
    "permissions-sync-android": "npx scrape-permissions-json@latest components/plugins/permissions/data --android",
    "versions-schema-sync": "node ./scripts/fetch-versions-schema.js",
    "react-navigation-docs-sync": "node ./scripts/fetch-react-navigation-options.js",
    "eas-cli-sync": "node ./ui/components/EASCLIReference/eas-cli-rerference.js",
    "expo-skills-sync": "node --experimental-strip-types ./ui/components/ExpoSkillsTable/sync-expo-skills.js",
    "expo-mcp-sync": "node --experimental-strip-types --env-file=.env ./ui/components/ExpoMCPToolsTable/sync-expo-mcp-tools.js",
    "install-vale": "node --experimental-strip-types scripts/install-vale.ts",
    "postinstall": "pnpm copy-latest && pnpm generate-static-resources && pnpm install-vale"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@expo/styleguide": "^13.1.1",
    "@expo/styleguide-base": "^3.0.4",
    "@expo/styleguide-cookie-consent": "^2.0.3",
    "@expo/styleguide-icons": "^4.0.6",
    "@expo/styleguide-search-ui": "^8.1.1",
    "@kapaai/react-sdk": "^0.9.6",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reach/tabs": "^0.18.0",
    "@sentry/nextjs": "^10.48.0",
    "@sentry/react": "^10.48.0",
    "@xyflow/react": "^12.10.2",
    "clipboard-copy": "^4.0.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "front-matter": "^4.0.2",
    "github-slugger": "^2.0.0",
    "lodash": "^4.18.1",
    "next": "16.2.3",
    "nprogress": "0.2.0",
    "path-browserify": "^1.0.1",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-confetti-explosion": "^3.0.3",
    "react-diff-view": "^3.3.3",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-player": "^3.4.0",
    "react-qr-code": "^2.0.18",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-mdx-disable-explicit-jsx": "^0.1.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "tippy.js": "^6.3.7",
    "yet-another-react-lightbox": "^3.30.1"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.9.3",
    "@expo/spawn-async": "^1.7.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/google.analytics": "^0.0.46",
    "@types/gtag.js": "^0.0.20",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.18.11",
    "@types/nprogress": "^0.2.3",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/turndown": "^5.0.6",
    "acorn": "^8.16.0",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.4",
    "eslint-config-universe": "^15.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.4.0",
    "eslint-plugin-lodash": "^8.0.0",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-oxlint": "^1.59.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^62.0.0",
    "fs-extra": "^11.3.4",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-router-mock": "^0.9.13",
    "oxfmt": "0.43.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.19.0",
    "postcss": "^8.5.9",
    "react-test-renderer": "^19.2.5",
    "rehype-slug": "^6.0.0",
    "remark-cli": "^12.0.1",
    "remark-supersub": "^1.0.0",
    "remark-validate-links": "^13.1.0",
    "semver": "^7.7.4",
    "sitemap": "^9.0.1",
    "tailwindcss": "^4.2.2",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^6.0.3",
    "unist-builder": "^4.0.0",
    "unist-util-visit": "^5.1.0",
    "user-agent-data-types": "^0.4.2",
    "wrangler": "^4.63.0"
  },
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all"
  ],
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  },
  "pnpm": {
    "overrides": {
      "baseline-browser-mapping": "2.9.15"
    },
    "patchedDependencies": {
      "next@16.2.3": "patches/next@16.2.3.patch"
    }
  },
  "volta": {
    "node": "22.13.1"
  }
}
