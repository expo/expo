# MauriMesh Environment Configuration
# Copy this file to .env and fill in your values

# App Configuration
EXPO_PUBLIC_APP_NAME=MauriMesh
EXPO_PUBLIC_APP_VERSION=5.2.0
EXPO_PUBLIC_ENVIRONMENT=development

# Cloud Services
EXPO_PUBLIC_CLOUD_URL=https://jumpcode-mesh.emergent.host
EXPO_PUBLIC_API_KEY=your-api-key-here

# Push Notifications (Firebase)
EXPO_PUBLIC_FCM_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FCM_API_KEY=your-firebase-api-key

# Apple Push Notifications
EXPO_PUBLIC_APNS_KEY_ID=your-apns-key-id
EXPO_PUBLIC_APNS_TEAM_ID=your-apns-team-id

# Analytics (Optional)
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id

# Feature Flags
EXPO_PUBLIC_ENABLE_MESH=true
EXPO_PUBLIC_ENABLE_CALLS=true
EXPO_PUBLIC_ENABLE_ENCRYPTION=true
EXPO_PUBLIC_ENABLE_CLOUD_SYNC=false
