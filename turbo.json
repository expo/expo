{
  "$schema": "https://turborepo.dev/schema.json",
  "dangerouslyDisablePackageManagerCheck": true,
  "noUpdateNotifier": true,
  "concurrency": "90%",
  "tasks": {
    "build": {
      "outputs": [
        "build/**",
        "plugin/build/**",
        "cli/build/**",
        "utils/build/**"
      ],
      "outputLogs": "new-only",
      "dependsOn": [
        "^build"
      ]
    },
    "typecheck": {
      "outputs": [
        ".tsbuildinfo",
        "*/.tsbuildinfo"
      ],
      "outputLogs": "new-only"
    },
    "lint": {
      "cache": false
    },
    "test": {
      "cache": false
    }
  },
  "remoteCache": {
    "preflight": true,
    "apiUrl": "https://turbo.exp.host",
    "teamId": "team_expo",
    "teamSlug": "expo"
  }
}
