{
  "$schema": "https://turborepo.dev/schema.json",
  "dangerouslyDisablePackageManagerCheck": true,
  "tasks": {
    "build": {
      "outputs": ["build/**", "dist/**", "lib/**"],
      "outputLogs": "errors-only",
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": false
    },
    "test": {
      "cache": false
    }
  }
}
