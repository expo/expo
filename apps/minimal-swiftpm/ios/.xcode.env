# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Customize the NODE_BINARY variable here.
# For example, to use nvm with brew, add the following line
# . "$(brew --prefix nvm)/nvm.sh" --no-use
export NODE_BINARY=$(command -v node)

# hermesc lives inside the hermes-compiler npm package (a react-native dependency —
# resolve THROUGH react-native for pnpm strictness). CocoaPods apps get this from
# $PODS_ROOT/hermes-engine; a SwiftPM app has no Pods, and a baked store path goes
# stale on every hermes version roll, so resolve it dynamically.
export HERMES_CLI_PATH="$("$NODE_BINARY" --print "require('path').join(require('path').dirname(require.resolve('hermes-compiler/package.json', {paths: [require('path').dirname(require.resolve('react-native/package.json'))]})), 'hermesc/osx-bin/hermesc')" 2>/dev/null)"
