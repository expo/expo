{
  "name": "native-component-list",
  "version": "0.0.0",
  "description": "A list of the various APIs you can use with the Expo Go",
  "author": "Expo",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prebuild": "TEMPLATE_DIR=\"../../templates/expo-template-bare-minimum\" && cd \"$TEMPLATE_DIR\" && PACKED_FILE=$(npm pack) && mv \"$PACKED_FILE\" pack.tgz && cd - && npx expo prebuild --clean --template \"$TEMPLATE_DIR/pack.tgz\"",
    "build:web": "expo export -p web",
    "web": "expo start --web",
    "lint": "eslint .",
    "tsc": "tsc --noEmit -p ./tsconfig.json",
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-module-template",
        "expo-module-template-local"
      ],
      "ios": {
        "flags": {
          "inhibit_warnings": false
        }
      },
      "android": {
        "configuration": "api",
        "target": "react-native"
      }
    }
  },
