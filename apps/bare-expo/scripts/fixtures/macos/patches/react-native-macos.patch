+  // corrupt dispatch through that binary. The default impls in jsi.cpp use
+  // existing public Runtime/Object/Function APIs (Reflect.{get,deleteProperty})
+  // and so work uniformly across all Runtime subclasses.
+  Value getProperty(const Object&, const Value& name);
