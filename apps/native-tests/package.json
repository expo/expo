{
  "name": "native-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "expo": "workspace:*",
    "expo-background-task": "workspace:*",
    "expo-clipboard": "workspace:*",
    "expo-dev-client": "workspace:*",
    "expo-router": "workspace:*",
    "expo-image": "workspace:*",
    "expo-media-library": "workspace:*",
    "expo-notifications": "workspace:*",
    "expo-observe": "workspace:*",
    "expo-splash-screen": "workspace:*",
    "expo-updates": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.2"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9"
  },
  "expo": {
    "autolinking": {
      "exclude": [
        "expo-ads-facebook",
        "expo-ads-admob",
        "expo-apple-authentication",
        "expo-module-template"
      ],
      "ios": {
        "flags": {
          "inhibit_warnings": false
        }
      }
    }
  },
  "private": true
