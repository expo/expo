{
  "printWidth": 100,
  "tabWidth": 2,
  "singleQuote": true,
  "bracketSameLine": true,
  "trailingComma": "es5",
  "ignorePatterns": [
    "**/node_modules/**",
    "**/build/**",
    "**/dist/**",
    "**/vendor/**",
    "**/vendored/**",
    "**/__generated__/**",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/fixtures/**",
    "**/__fixtures__/**",
    "**/.expo/**",
    "**/.next/**",
    "**/assets/**",
    "**/android/**",
    "**/ios/**"
  ],
  "sortImports": {
    "groups": [
      ["builtin", "external"],
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "unknown"
    ],
    "ignoreCase": false
  }
}
