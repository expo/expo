{
  "name": "@expo/ui",
  "version": "55.0.1",
  "description": "A collection of UI components",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "source": "./src/universal/index.ts",
        "default": "./build/universal/index.d.ts"
      },
      "source": "./src/universal/index.ts",
      "default": "./build/universal/index.js"
    },
    "./swift-ui": {
      "types": {
        "source": "./src/swift-ui/index.tsx",
        "default": "./build/swift-ui/index.d.ts"
      },
      "source": "./src/swift-ui/index.tsx",
      "default": "./build/swift-ui/index.js"
    },
    "./swift-ui/modifiers": {
      "types": {
        "source": "./src/swift-ui/modifiers/index.ts",
        "default": "./build/swift-ui/modifiers/index.d.ts"
      },
      "source": "./src/swift-ui/modifiers/index.ts",
      "default": "./build/swift-ui/modifiers/index.js"
    },
    "./jetpack-compose": {
      "types": {
        "source": "./src/jetpack-compose/index.ts",
        "default": "./build/jetpack-compose/index.d.ts"
      },
      "source": "./src/jetpack-compose/index.ts",
      "default": "./build/jetpack-compose/index.js"
    },
    "./jetpack-compose/modifiers": {
      "types": {
        "source": "./src/jetpack-compose/modifiers/index.ts",
        "default": "./build/jetpack-compose/modifiers/index.d.ts"
      },
      "source": "./src/jetpack-compose/modifiers/index.ts",
      "default": "./build/jetpack-compose/modifiers/index.js"
    },
    "./datetimepicker": {
      "types": {
        "source": "./src/datetime-picker/index.tsx",
        "default": "./build/datetime-picker/index.d.ts"
      },
      "source": "./src/datetime-picker/index.tsx",
      "default": "./build/datetime-picker/index.js"
    },
    "./community/bottom-sheet": {
      "types": "./build/community/bottom-sheet/index.d.ts",
      "default": "./src/community/bottom-sheet/index.tsx"
    },
    "./community/segmented-control": {
      "types": {
        "source": "./src/community/segmented-control/index.tsx",
        "default": "./build/community/segmented-control/index.d.ts"
      },
      "source": "./src/community/segmented-control/index.tsx",
      "default": "./build/community/segmented-control/index.js"
    },
    "./community/picker": {
      "types": {
        "source": "./src/community/picker/index.tsx",
        "default": "./build/community/picker/index.d.ts"
      },
      "source": "./src/community/picker/index.tsx",
      "default": "./build/community/picker/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module"
  },
  "homepage": "https://docs.expo.dev/versions/latest/sdk/ui/",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-ui"
  },
  "keywords": [
    "react",
    "react-native",
    "expo",
    "UI components",
    "SwiftUI",
    "Jetpack Compose",
    "cross platform",
    "web",
    "universal"
  ],
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "dependencies": {
    "sf-symbols-typescript": "^2.1.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.0",
    "@types/react": "~19.2.0",
    "expo-module-scripts": "workspace:*",
    "react-native-reanimated": "4.3.0",
    "react-native-worklets": "0.8.1"
  },
  "jest": {
    "preset": "expo-module-scripts"
  },
  "peerDependencies": {
    "expo": "workspace:*",
    "react": "*",
    "react-dom": "*",
    "react-native": "*",
    "react-native-reanimated": "*",
    "react-native-worklets": "*"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-worklets": {
      "optional": true
    }
  }
}
