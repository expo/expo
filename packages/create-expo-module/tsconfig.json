{
  "extends": "expo-module-scripts/tsconfig.node",
  "include": ["./src"],
  "exclude": ["**/__mocks__/*", "**/__tests__/*"],
  "compilerOptions": {
    "outDir": "./build",
    "module": "commonjs",
    "moduleResolution": "node",
    "sourceMap": true,
    "declaration": true,
    "inlineSources": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  }
}
