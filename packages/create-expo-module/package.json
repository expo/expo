{
  "name": "create-expo-module",
  "version": "2.1.4",
  "description": "The script to create the Expo module",
  "keywords": [
    "expo",
    "module",
    "modules",
    "library",
    "react",
    "native"
  ],
  "license": "MIT",
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/create-expo-module"
  },
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "author": "Expo",
  "bin": "build/index.js",
  "main": "build/index.js",
  "files": [
    "bin",
    "build"
  ],
  "engines": {
    "node": ">=18.13.0"
  },
  "scripts": {
    "build": "ncc build ./src/index.ts -o build/",
    "build:prod": "ncc build ./src/index.ts -o build/ --minify --no-cache --no-source-map-register",
    "prepare": "yarn run clean && yarn run build:prod",
    "clean": "rm -rf build",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config e2e/jest.config.js --runInBand",
    "watch": "yarn run build --watch"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-export-namespace-from": "^7.23.4",
    "@babel/plugin-transform-modules-commonjs": "^7.23.4",
    "@babel/preset-env": "^7.23.8",
    "@babel/preset-typescript": "^7.23.3",
    "@expo/json-file": "^10.0.12",
    "@expo/rudder-sdk-node": "^1.1.1",
    "@expo/spawn-async": "^1.7.2",
    "@octokit/types": "^15.0.0",
    "@types/ejs": "^3.1.5",
    "@types/jest": "^29.2.1",
    "@types/prompts": "^2.4.9",
    "@vercel/ncc": "^0.38.4",
    "babel-jest": "^29.7.0",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "chalk": "^4.1.2",
    "commander": "^8.3.0",
    "cross-spawn": "^7.0.5",
    "debug": "^4.3.4",
    "ejs": "^3.1.10",
    "eslint": "^8.57.1",
    "eslint-config-universe": "^15.0.3",
    "getenv": "^2.0.0",
    "jest": "^29.7.0",
    "jest-snapshot-prettier": "npm:prettier@^2",
    "jest-watch-typeahead": "2.2.1",
    "ora": "^5.4.1",
    "prompts": "^2.4.2",
    "tar": "^7.5.2",
    "typescript": "^5.9.2",
    "validate-npm-package-name": "^6.0.2"
  }
}
