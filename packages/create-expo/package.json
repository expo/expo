{
  "name": "create-expo",
  "version": "3.6.6",
  "bin": "./bin/create-expo.js",
  "main": "build",
  "description": "Create universal Expo apps",
  "license": "BSD-3-Clause",
  "keywords": [
    "expo",
    "react-native",
    "react"
  ],
  "homepage": "https://docs.expo.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/create-expo"
  },
  "author": "Evan Bacon <bacon@expo.io> (https://github.com/evanbacon)",
  "files": [
    "bin",
    "build",
    "template"
  ],
  "engines": {
    "node": ">=18.13.0"
  },
  "scripts": {
    "build": "ncc build ./src/index.ts -o build/",
    "build:prod": "ncc build ./src/index.ts -o build/ --minify --no-cache --no-source-map-register",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "typecheck": "expo-module typecheck",
    "test": "expo-module test",
    "test:e2e": "expo-module test --config e2e/jest.config.js --runInBand",
    "watch": "pnpm run build --watch",
    "prepublishOnly": "pnpm run clean && pnpm run build:prod"
  },
  "devDependencies": {
    "@expo/config": "workspace:*",
    "@expo/json-file": "workspace:*",
    "@expo/package-manager": "workspace:*",
    "@expo/spawn-async": "^1.7.2",
    "@octokit/types": "^13.5.0",
    "@types/debug": "catalog:",
    "@types/getenv": "^1.0.0",
    "@types/node": "catalog:",
    "@types/picomatch": "catalog:",
    "@types/prompts": "catalog:",
    "@vercel/ncc": "^0.38.3",
    "arg": "^5.0.2",
    "chalk": "catalog:",
    "debug": "catalog:",
    "expo-module-scripts": "workspace:*",
    "getenv": "^2.0.0",
    "glob": "^13.0.0",
    "nock": "^14.0.10",
    "ora": "3.4.0",
    "picomatch": "catalog:",
    "prompts": "catalog:",
    "multitars": "catalog:",
    "update-check": "^1.5.4"
  }
}
