{
  "name": "expo-brownfield",
  "version": "56.0.15",
  "description": "Toolkit and APIs for adding brownfield setup to Expo projects",
  "keywords": [
    "brownfield",
    "expo",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/unversioned/sdk/brownfield/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-brownfield"
  },
  "bin": "./bin/cli.js",
  "sideEffects": false,
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json",
    "./app.plugin.js": "./app.plugin.js",
    "./plugin": "./plugin/build/index.js"
  },
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin && pnpm run build:cli",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "build:cli": "expo-build --base cli cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "lint:fix": "oxlint --config oxlint.config.mjs . --fix",
    "format": "expo-module format",
    "test": "jest",
    "test:e2e-cli": "jest --config e2e/cli/jest.config.js",
    "test:e2e-plugin": "jest --config e2e/plugin/jest.config.js",
    "prepack": "node scripts/resolve-symlinks.js resolve",
    "postpack": "node scripts/resolve-symlinks.js restore",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -b tsconfig.all.json"
  },
  "dependencies": {
    "@expo/env": "workspace:~2.3.0",
    "@expo/spawn-async": "^1.8.0",
    "commander": "^14.0.3",
    "diff": "^5.2.0",
    "expo-build-properties": "workspace:~56.0.15",
    "expo-manifests": "workspace:~56.0.4",
    "ora": "^5.4.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@bacons/xcode": "1.0.0-alpha.29",
    "@types/diff": "^5.2.0",
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "@types/prompts": "^2.0.6",
    "@types/react": "~19.2.0",
    "create-expo": "workspace:*",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*",
    "glob": "^13.0.6"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
