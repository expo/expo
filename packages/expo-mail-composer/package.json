{
  "name": "expo-mail-composer",
  "version": "56.0.4",
  "description": "Provides an API to compose mails using OS specific UI",
  "keywords": [
    "composer",
    "expo",
    "mail",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/mail-composer/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-mail-composer"
  },
  "sideEffects": false,
  "main": "build/MailComposer.js",
  "types": "build/MailComposer.d.ts",
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -b tsconfig.all.json"
  },
  "devDependencies": {
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
