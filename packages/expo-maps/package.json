{
  "name": "expo-maps",
  "version": "55.0.9",
  "description": "Provides a Map component that uses Google Maps on Android and Apple Maps on iOS.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepublishOnly": "expo-module prepublishOnly"
  },
  "homepage": "https://docs.expo.dev/versions/latest/sdk/maps/",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-ui"
  },
  "keywords": [
    "react-native",
    "expo",
    "UI components"
  ],
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "workspace:*",
    "react": "*",
    "react-native": "*"
  },
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  }
}
