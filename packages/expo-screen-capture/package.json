{
  "name": "expo-screen-capture",
  "version": "56.0.4",
  "description": "Protects screens in your app from being captured or recorded, and notifies if a screenshot is taken.",
  "keywords": [
    "expo",
    "expo-screen-capture",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/screen-capture",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-screen-capture"
  },
  "main": "build/ScreenCapture.js",
  "types": "build/ScreenCapture.d.ts",
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "pnpm clean && turbo run build",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@testing-library/react-native": "^13.3.0",
    "@types/react": "~19.2.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
