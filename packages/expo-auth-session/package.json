{
  "name": "expo-auth-session",
  "version": "56.0.12",
  "description": "Expo module for browser-based authentication",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./providers/facebook": {
      "types": {
        "source": "./src/providers/Facebook.ts",
        "default": "./build/providers/Facebook.d.ts"
      },
      "source": "./src/providers/Facebook.ts",
      "default": "./build/providers/Facebook.js"
    },
    "./providers/facebook.js": {
      "types": {
        "source": "./src/providers/Facebook.ts",
        "default": "./build/providers/Facebook.d.ts"
      },
      "source": "./src/providers/Facebook.ts",
      "default": "./build/providers/Facebook.js"
    },
    "./providers/google": {
      "types": {
        "source": "./src/providers/Google.ts",
        "default": "./build/providers/Google.d.ts"
      },
      "source": "./src/providers/Google.ts",
      "default": "./build/providers/Google.js"
    },
    "./providers/google.js": {
      "types": {
        "source": "./src/providers/Google.ts",
        "default": "./build/providers/Google.d.ts"
      },
      "source": "./src/providers/Google.ts",
      "default": "./build/providers/Google.js"
    },
    "./build/PKCE": {
      "types": {
        "source": "./src/PKCE.ts",
        "default": "./build/PKCE.d.ts"
      },
      "source": "./src/PKCE.ts",
      "default": "./build/PKCE.js"
    },
    "./build/PKCE.js": {
      "types": {
        "source": "./src/PKCE.ts",
        "default": "./build/PKCE.d.ts"
      },
      "source": "./src/PKCE.ts",
      "default": "./build/PKCE.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-auth-session",
    "auth",
    "oauth",
    "authentication",
    "auth-session"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-auth-session"
  },
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "homepage": "https://docs.expo.dev/versions/latest/sdk/auth-session",
  "dependencies": {
    "expo-application": "workspace:~56.0.3",
    "expo-constants": "workspace:~56.0.16",
    "expo-crypto": "workspace:~56.0.4",
    "expo-linking": "workspace:~56.0.12",
    "expo-web-browser": "workspace:~56.0.5",
    "invariant": "^2.2.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "@types/invariant": "^2.2.33",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
