{
  "name": "@expo/config",
  "version": "56.0.9",
  "description": "A library for interacting with the app.json",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./paths": {
      "types": {
        "expo-source": "./src/paths/index.ts",
        "default": "./build/paths/index.d.ts"
      },
      "expo-source": "./src/paths/index.ts",
      "default": "./build/paths/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "lint:oxlint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/config"
  },
  "keywords": [
    "json",
    "react-native",
    "expo",
    "react"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/config#readme",
  "files": [
    "build",
    "paths"
  ],
  "dependencies": {
    "@expo/config-plugins": "workspace:~56.0.8",
    "@expo/config-types": "workspace:^56.0.5",
    "@expo/json-file": "workspace:^10.2.0",
    "@expo/require-utils": "workspace:^56.1.3",
    "deepmerge": "^4.3.1",
    "getenv": "^2.0.0",
    "glob": "^13.0.0",
    "resolve-workspace-root": "^2.0.0",
    "semver": "^7.6.0",
    "slugify": "^1.3.4"
  },
  "devDependencies": {
    "@types/babel__code-frame": "^7.27.0",
    "@types/getenv": "^1.0.0",
    "@types/semver": "^7.5.8",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
