{
  "name": "@expo/plist",
  "version": "0.7.0",
  "description": "Mac OS X Plist parser/builder for Node.js and browsers",
  "keywords": [
    "plist"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/plist#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/plist"
  },
  "files": [
    "build"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json",
    "test": "jest",
    "prepublishOnly": "pnpm run clean && turbo run build"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.8",
    "base64-js": "^1.5.1",
    "xmlbuilder": "^15.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "expo-module-scripts": "workspace:*"
  }
}
