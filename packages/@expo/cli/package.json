{
  "name": "@expo/cli",
  "version": "56.1.12",
  "description": "The Expo CLI",
  "keywords": [
    "cli",
    "expo"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/cli",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "Expo",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/cli"
  },
  "bin": {
    "expo-internal": "bin/cli.js"
  },
  "files": [
    "main.js",
    "internal",
    "static",
    "build"
  ],
  "main": "main.js",
  "exports": {
    "./package.json": "./package.json",
    "./static/template/*": "./static/template/*",
    ".": {
      "expo-source": "./src/index.ts",
      "default": "./build/src/index.js"
    },
    "./ts-declarations/react-server-dom-webpack": "./ts-declarations/react-server-dom-webpack/index.d.ts",
    "./ts-declarations/*": "./ts-declarations/*",
    "./*": "./*.js",
    "./*.js": "./*.js"
  },
  "scripts": {
    "build": "pnpm run build:cli && pnpm run build:metro-require",
    "build:cli": "expo-build cjs:src=build/src",
    "build:metro-require": "expo-build script:metro-require=build/metro-require",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json",
    "test": "jest",
    "test:e2e": "jest --config e2e/jest.config.js",
    "test:playwright": "playwright test --config e2e/playwright.config.ts"
  },
  "dependencies": {
    "@expo/code-signing-certificates": "^0.0.6",
    "@expo/config": "workspace:~56.0.9",
    "@expo/config-plugins": "workspace:~56.0.8",
    "@expo/devcert": "^1.2.1",
    "@expo/env": "workspace:~2.3.0",
    "@expo/image-utils": "workspace:^0.10.1",
    "@expo/inline-modules": "workspace:^0.0.10",
    "@expo/json-file": "workspace:^10.2.0",
    "@expo/log-box": "workspace:^56.0.12",
    "@expo/log-box-utils": "workspace:^56.0.0",
    "@expo/metro": "~56.0.0",
    "@expo/metro-config": "workspace:~56.0.13",
    "@expo/metro-file-map": "workspace:^56.0.3",
    "@expo/osascript": "workspace:^2.6.0",
    "@expo/package-manager": "workspace:^1.12.0",
    "@expo/plist": "workspace:^0.7.0",
    "@expo/prebuild-config": "workspace:^56.0.13",
    "@expo/require-utils": "workspace:^56.1.3",
    "@expo/router-server": "workspace:^56.0.12",
    "@expo/schema-utils": "workspace:^56.0.0",
    "@expo/spawn-async": "^1.8.0",
    "@expo/ws-tunnel": "^2.0.0",
    "@expo/xcpretty": "^4.4.4",
    "@react-native/dev-middleware": "0.86.0",
    "accepts": "^1.3.8",
    "arg": "^5.0.2",
    "bplist-creator": "0.1.0",
    "bplist-parser": "^0.3.1",
    "chalk": "^4.0.0",
    "ci-info": "^3.3.0",
    "compression": "^1.7.4",
    "connect": "^3.7.0",
    "debug": "^4.3.4",
    "dnssd-advertise": "^1.1.6",
    "expo-server": "workspace:^56.0.4",
    "fetch-nodeshim": "^0.4.10",
    "getenv": "^2.0.0",
    "glob": "^13.0.0",
    "lan-network": "^0.2.1",
    "multitars": "^1.0.0",
    "node-forge": "^1.3.3",
    "npm-package-arg": "^11.0.0",
    "ora": "^3.4.0",
    "picomatch": "^4.0.4",
    "pretty-format": "^29.7.0",
    "progress": "^2.0.3",
    "prompts": "^2.3.2",
    "resolve-from": "^5.0.0",
    "semver": "^7.6.0",
    "send": "^0.19.0",
    "slugify": "^1.3.4",
    "stacktrace-parser": "^0.1.10",
    "structured-headers": "^0.4.1",
    "terminal-link": "^2.1.1",
    "toqr": "^0.1.1",
    "wrap-ansi": "^7.0.0",
    "ws": "^8.12.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/fingerprint": "workspace:*",
    "@expo/mcp-tunnel": "~0.2.3",
    "@expo/ngrok": "^4.1.3",
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.59.0",
    "@types/accepts": "^1.3.5",
    "@types/babel__core": "^7.20.5",
    "@types/connect": "^3.4.33",
    "@types/cross-spawn": "^6.0.6",
    "@types/debug": "^4.1.7",
    "@types/eslint": "^8.56.12",
    "@types/execa": "^0.9.0",
    "@types/express": "^5.0.3",
    "@types/getenv": "^1.0.0",
    "@types/klaw-sync": "^6.0.0",
    "@types/node": "^22.14.0",
    "@types/npm-package-arg": "^6.1.0",
    "@types/picomatch": "^4.0.2",
    "@types/progress": "^2.0.5",
    "@types/prompts": "^2.0.6",
    "@types/react": "~19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/resolve": "^1.20.2",
    "@types/semver": "^7.5.8",
    "@types/send": "^0.17.1",
    "@types/webpack": "~4.41.32",
    "@types/webpack-dev-server": "^3.11.0",
    "@types/wrap-ansi": "^3.0.0",
    "@types/ws": "^8.5.4",
    "devtools-protocol": "^0.0.1113120",
    "eslint": "^9.18.0",
    "expect": "^29.7.0",
    "expo-atlas": "^0.4.1",
    "expo-module-scripts": "workspace:*",
    "expo-modules-autolinking": "workspace:*",
    "expo-router": "workspace:*",
    "find-process": "^1.4.7",
    "jest-matcher-utils": "^29.7.0",
    "klaw-sync": "^6.0.0",
    "memfs": "^3.2.0",
    "nock": "^14.0.10",
    "node-html-parser": "^6.1.5",
    "playwright": "^1.59.0",
    "react": "*",
    "react-refresh": "^0.14.2",
    "react-test-renderer": "19.2.3",
    "tree-kill": "^1.2.2"
  },
  "peerDependencies": {
    "expo": "*",
    "expo-router": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
