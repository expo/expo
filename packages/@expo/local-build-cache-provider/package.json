{
  "name": "@expo/local-build-cache-provider",
  "version": "56.0.8",
  "description": "Local build cache provider for Expo",
  "keywords": [
    "build-cache-provider",
    "expo",
    "local-build-cache",
    "react-native"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/local-build-cache-provider#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/local-build-cache-provider"
  },
  "files": [
    "build"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@expo/config": "workspace:~56.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0"
  }
}
