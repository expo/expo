{
  "extends": "./tsconfig",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "./src",
    "outDir": "./build"
  },
  "include": ["src/**/*"],
  "exclude": [
    "app/**/*",
    "android/**/*",
    "ios/**/*",
    "dist/**/*",
    "build/**/*",
    "**/__mocks__/*",
    "**/__tests__/*"
  ]
}
