{
  "extends": "expo-module-scripts/tsconfig.base",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "customConditions": ["react-native-strict-api-UNSAFE-ALLOW-SUBPATHS", "expo-source"]
  },
  "include": ["src/**/*"],
  "exclude": ["app/**/*", "dist/**/*", "build/**/*"]
}
