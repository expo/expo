{
  "extends": "expo-module-scripts/tsconfig.node",
  "compilerOptions": {
    "rootDir": ".",
    "lib": ["dom", "DOM.Iterable", "esnext"],
    "jsx": "react",
    "plugins": [{ "name": "typescript-plugin-css-modules" }],
    "customConditions": ["react-native-strict-api-UNSAFE-ALLOW-SUBPATHS"]
  },
  "include": ["src/**/*", "app/**/*"],
  "exclude": ["**/__mocks__/*", "**/__tests__/*"]
}
