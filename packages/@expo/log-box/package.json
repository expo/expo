{
  "name": "@expo/log-box",
  "version": "55.0.7",
  "main": "app/index.ts",
  "exports": {
    ".": "./app/index.ts",
    "./utils": {
      "types": {
        "source": "./src/utils.ts",
        "default": "./build/utils.d.ts"
      },
      "source": "./src/utils.ts",
      "default": "./build/utils.js"
    },
    "./package.json": "./package.json",
    "./lib": "./lib.ts",
    "./lib.ts": "./lib.ts",
    "./src/*": "./src/*.ts",
    "./src/*.ts": "./src/*.ts",
    "./*.js": "./*.js",
    "./*": "./*.js"
  },
  "scripts": {
    "start": "expo start",
    "lint": "expo-module lint",
    "typecheck": "expo-module typecheck",
    "clean": "run-p clean:lib clean:bundle",
    "clean:lib": "rimraf build",
    "clean:bundle": "rimraf dist",
    "watch": "run-p watch:bundle",
    "watch:bundle": "node ./scripts/watch-bundle.mjs",
    "prepublishOnly": "run-s clean build",
    "build": "run-s build:lib build:bundle",
    "build:lib": "expo-build src",
    "build:bundle": "node ./scripts/build-bundle.mjs",
    "export:web": "expo export -p web --no-minify"
  },
  "dependencies": {
    "@expo/dom-webview": "workspace:^55.0.3",
    "anser": "^1.4.9",
    "stacktrace-parser": "^0.1.10"
  },
  "devDependencies": {
    "@expo/spawn-async": "^1.7.2",
    "@types/react": "~19.2.0",
    "@types/react-dom": "^19.1.7",
    "expo-module-scripts": "workspace:*",
    "glob": "^13.0.0",
    "npm-run-all2": "^8.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.2",
    "react-native-web": "^0.21.0",
    "rimraf": "^6.1.2",
    "typescript-plugin-css-modules": "^5.2.0"
  },
  "peerDependencies": {
    "@expo/dom-webview": "workspace:^55.0.3",
    "expo": "workspace:*",
    "react": "*",
    "react-native": "*"
  },
  "license": "MIT",
  "author": "Expo",
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/log-box",
  "description": "Error overlay for universal Expo apps."
}
