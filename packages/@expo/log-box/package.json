{
  "name": "@expo/log-box",
  "version": "56.0.12",
  "description": "Error overlay for universal Expo apps.",
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/log-box",
  "license": "MIT",
  "author": "Expo",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.tsx",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.tsx",
      "default": "./build/index.js"
    },
    "./lib": {
      "types": {
        "expo-source": "./src/index.tsx",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.tsx",
      "default": "./build/index.js"
    },
    "./LogBox": {
      "types": {
        "expo-source": "./src/LogBox.ts",
        "default": "./build/LogBox.d.ts"
      },
      "expo-source": "./src/LogBox.ts",
      "default": "./build/LogBox.js"
    },
    "./swap-rn-logbox.js": "./swap-rn-logbox.js",
    "./swap-rn-logbox-parser.js": "./swap-rn-logbox-parser.js",
    "./logbox-web-polyfill": {
      "types": {
        "expo-source": "./src/logbox-web-polyfill.tsx",
        "default": "./build/logbox-web-polyfill.d.ts"
      },
      "expo-source": "./src/logbox-web-polyfill.tsx",
      "default": "./build/logbox-web-polyfill.js"
    },
    "./Data/LogBoxLog": {
      "types": {
        "expo-source": "./src/Data/LogBoxLog.ts",
        "default": "./build/Data/LogBoxLog.d.ts"
      },
      "expo-source": "./src/Data/LogBoxLog.ts",
      "default": "./build/Data/LogBoxLog.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "expo start",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc",
    "clean": "run-p clean:lib clean:bundle",
    "clean:lib": "rimraf build",
    "clean:bundle": "rimraf dist",
    "prepublishOnly": "run-s clean build:publish",
    "build": "run-s build:lib",
    "build:publish": "run-s build:lib build:bundle",
    "build:lib": "expo-build src",
    "build:bundle": "node ./scripts/build-bundle.mjs",
    "export:web": "expo export -p web --no-minify"
  },
  "dependencies": {
    "@expo/dom-webview": "workspace:^56.0.5",
    "@expo/log-box-utils": "workspace:^56.0.0",
    "anser": "^1.4.9",
    "expo-modules-core": "workspace:~56.0.13",
    "stacktrace-parser": "^0.1.10"
  },
  "devDependencies": {
    "@expo/spawn-async": "^1.8.0",
    "@types/react": "~19.2.0",
    "@types/react-dom": "^19.1.7",
    "expo-module-scripts": "workspace:*",
    "glob": "^13.0.0",
    "npm-run-all2": "^8.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.87.0-rc.0",
    "react-native-web": "^0.21.0",
    "rimraf": "^6.1.2"
  },
  "peerDependencies": {
    "@expo/dom-webview": "workspace:^56.0.5",
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  }
}
