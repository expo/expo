{
  "name": "@expo/devtools",
  "version": "56.0.2",
  "description": "DevTools plugin helpers for Expo",
  "keywords": [
    "cli-extensions",
    "dev-plugins",
    "devtools",
    "expo",
    "plugins",
    "react",
    "react-native"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/devtools#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/devtools"
  },
  "files": [
    "build"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "@types/ws": "^8.5.4",
    "expo-module-scripts": "workspace:*",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  }
}
