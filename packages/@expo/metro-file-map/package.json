{
  "name": "@expo/metro-file-map",
  "version": "56.0.0",
  "description": "A metro-file-map fork for Expo used with the Metro bundler",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-module tsc",
    "clean": "expo-module clean",
