{
  "name": "@expo/dom-webview",
  "version": "55.0.3",
  "description": "A WebView specifically designed for Expo DOM components",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": {
        "source": "src/index.ts",
        "default": "build/index.d.ts"
      },
      "source": "src/index.ts",
      "default": "build/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module",
    "syncBrowserScripts": "./scripts/buildBrowserScripts.ts"
  },
  "keywords": [
    "react-native",
    "expo",
    "dom",
    "webview"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/dom-webview"
  },
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/dom-webview",
  "jest": {
    "preset": "expo-module-scripts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "~19.2.0",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "workspace:*",
    "react": "*",
    "react-native": "*"
  }
}
