{
  "name": "@expo/metro-config",
  "version": "56.0.13",
  "description": "A Metro config for running React Native projects with the Metro bundler",
  "keywords": [
    "expo",
    "metro"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/metro-config#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/metro-config"
  },
  "files": [
    "build",
    "file-store",
    "babel-transformer"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "require": "./build/index.js",
      "default": "./build/index.js"
    },
    "./babel-transformer": {
      "types": {
        "expo-source": "./src/babel-transformer.ts",
        "default": "./build/babel-transformer.d.ts"
      },
      "expo-source": "./src/babel-transformer.ts",
      "require": "./build/babel-transformer.js",
      "default": "./build/babel-transformer.js"
    },
    "./file-store": {
      "types": {
        "expo-source": "./src/file-store.ts",
        "default": "./build/file-store.d.ts"
      },
      "expo-source": "./src/file-store.ts",
      "require": "./build/file-store.js",
      "default": "./build/file-store.js"
    },
    "./babel-transformer.js": "./build/babel-transformer.js",
    "./file-store.js": "./build/file-store.js",
    "./package.json": "./package.json",
    "./*": "./*.js",
    "./*.js": "./*.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "2g": "^0.4.3",
    "@babel/code-frame": "^7.20.0",
    "@babel/core": "^7.20.0",
    "@babel/generator": "^7.20.5",
    "@expo/config": "workspace:~56.0.9",
    "@expo/env": "workspace:~2.3.0",
    "@expo/json-file": "workspace:~10.2.0",
    "@expo/metro": "~56.0.0",
    "@expo/require-utils": "workspace:^56.1.3",
    "@expo/spawn-async": "^1.8.0",
    "@jridgewell/gen-mapping": "^0.3.13",
    "@jridgewell/remapping": "^2.3.5",
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@react-native/js-polyfills": "0.86.0",
    "browserslist": "^4.25.0",
    "chalk": "^4.1.0",
    "debug": "^4.3.2",
    "getenv": "^2.0.0",
    "glob": "^13.0.0",
    "hermes-parser": "^0.36.0",
    "jsc-safe-url": "^0.2.4",
    "lightningcss": "^1.30.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "resolve-from": "^5.0.0"
  },
  "devDependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@types/babel__code-frame": "^7.0.1",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/getenv": "^1.0.0",
    "@types/picomatch": "^4.0.2",
    "dedent": "^1.5.3",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0",
    "metro-minify-terser": "^0.84.2",
    "sass": "^1.60.0"
  },
  "peerDependencies": {
    "expo": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  }
}
