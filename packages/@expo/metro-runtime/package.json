{
  "name": "@expo/metro-runtime",
  "version": "55.0.6",
  "description": "Tools for making advanced Metro bundler features work",
  "sideEffects": true,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/metro-runtime",
  "keywords": [],
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./rsc/runtime": "./rsc/runtime.js",
    "./package.json": "./package.json"
  },
  "files": [
    "build",
    "src",
    "rsc",
    "assets",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git"
  },
  "peerDependencies": {
    "expo": "workspace:*",
    "react": "*",
    "react-dom": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@expo/log-box": "workspace:55.0.7",
    "anser": "^1.4.9",
    "stacktrace-parser": "^0.1.10",
    "pretty-format": "^29.7.0",
    "whatwg-fetch": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "expo-constants": "workspace:*",
    "expo-module-scripts": "workspace:*",
    "react-dom": "19.2.3"
  }
}
