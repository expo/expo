{
  "name": "@expo/require-utils",
  "version": "56.1.3",
  "description": "Reusable require and Node resolution utilities library for Expo",
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/require-utils#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/require-utils"
  },
  "files": [
    "build"
  ],
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "generate": "node ./scripts/generate.js",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@babel/code-frame": "^7.20.0",
    "@babel/core": "^7.29.6",
    "@babel/plugin-transform-modules-commonjs": "^7.24.8"
  },
  "devDependencies": {
    "@types/babel__code-frame": "^7.27.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.14.0",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0 || ^5.0.0-0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
