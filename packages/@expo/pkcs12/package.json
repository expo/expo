    "directory": "packages/@expo/pkcs12"
  },
  "dependencies": {
    "node-forge": "^1.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/node-forge": "^1.0.0",
    "expo-module-scripts": "workspace:*"
  },
  "publishConfig": {
