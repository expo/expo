{
  "name": "@expo/config-plugins",
  "version": "56.0.8",
  "description": "A library for Expo config plugins",
  "keywords": [
    "expo",
    "json",
    "react",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/guides/config-plugins/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/config-plugins"
  },
  "files": [
    "build",
    "paths"
  ],
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./build/android": {
      "types": {
        "expo-source": "./src/android/index.ts",
        "default": "./build/android/index.d.ts"
      },
      "expo-source": "./src/android/index.ts",
      "default": "./build/android/index.js"
    },
    "./build/ios": {
      "types": {
        "expo-source": "./src/ios/index.ts",
        "default": "./build/ios/index.d.ts"
      },
      "expo-source": "./src/ios/index.ts",
      "default": "./build/ios/index.js"
    },
    "./build": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./build/*.js": {
      "types": {
        "expo-source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "expo-source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./build/*": {
      "types": {
        "expo-source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "expo-source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@expo/config-types": "workspace:^56.0.5",
    "@expo/json-file": "workspace:~10.2.0",
    "@expo/plist": "workspace:^0.7.0",
    "@expo/require-utils": "workspace:^56.1.3",
    "@expo/sdk-runtime-versions": "^1.0.0",
    "chalk": "^4.1.2",
    "debug": "^4.3.5",
    "getenv": "^2.0.0",
    "glob": "^13.0.0",
    "semver": "^7.5.4",
    "slugify": "^1.6.6",
    "xcode": "^3.0.1",
    "xml2js": "0.6.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.5",
    "@types/getenv": "^1.0.0",
    "@types/semver": "^7.7.0",
    "@types/xml2js": "~0.4.11",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0"
  }
}
