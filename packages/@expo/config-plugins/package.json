{
  "name": "@expo/config-plugins",
  "version": "55.0.6",
  "description": "A library for Expo config plugins",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./build/android": {
      "types": {
        "source": "./src/android/index.ts",
        "default": "./build/android/index.d.ts"
      },
      "source": "./src/android/index.ts",
      "default": "./build/android/index.js"
    },
    "./build/ios": {
      "types": {
        "source": "./src/ios/index.ts",
        "default": "./build/ios/index.d.ts"
      },
      "source": "./src/ios/index.ts",
      "default": "./build/ios/index.js"
    },
    "./build": {
      "types": {
        "source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./build/*.js": {
      "types": {
        "source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./build/*": {
      "types": {
        "source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "expo-module test",
    "typecheck": "expo-module typecheck"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/config-plugins"
  },
  "keywords": [
    "json",
    "expo",
    "react-native",
    "react"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "homepage": "https://docs.expo.dev/guides/config-plugins/",
  "files": [
    "build",
    "paths"
  ],
  "dependencies": {
    "@expo/config-types": "workspace:^55.0.5",
    "@expo/json-file": "workspace:~10.0.12",
    "@expo/plist": "workspace:^0.5.2",
    "@expo/sdk-runtime-versions": "^1.0.0",
    "chalk": "^4.1.2",
    "debug": "^4.3.5",
    "getenv": "^2.0.0",
    "glob": "^13.0.0",
    "resolve-from": "^5.0.0",
    "semver": "^7.5.4",
    "slugify": "^1.6.6",
    "xcode": "^3.0.1",
    "xml2js": "0.6.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@types/debug": "^4.1.5",
    "@types/getenv": "^1.0.0",
    "@types/semver": "^7.7.0",
    "@types/xml2js": "~0.4.11",
    "expo-module-scripts": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
