{
  "name": "@expo/package-manager",
  "version": "1.12.0",
  "description": "A library for installing and finding packages in a project",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "lint:oxlint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/package-manager"
  },
  "keywords": [
    "react-native",
    "package-manager",
    "package-json",
    "node",
    "yarn",
    "yarnpkg",
    "pnpm",
    "bun"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/package-manager#readme",
  "files": [
    "build"
  ],
  "dependencies": {
    "@expo/json-file": "workspace:^10.2.0",
    "@expo/spawn-async": "^1.8.0",
    "chalk": "^4.0.0",
    "npm-package-arg": "^11.0.0",
    "ora": "^3.4.0",
    "resolve-workspace-root": "^2.0.0"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.2",
    "@types/npm-package-arg": "^6.1.0",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0",
    "strip-ansi": "^6.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
