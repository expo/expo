{
  "name": "@expo/config-types",
  "version": "56.0.5",
  "description": "Types for the Expo config object app.config.ts",
  "keywords": [
    "app.config.js",
    "app.json",
    "expo",
    "json",
    "react",
    "react-native"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/@expo/config-types#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/@expo/config-types"
  },
  "files": [
    "build"
  ],
  "main": "build/ExpoConfig.js",
  "types": "build/ExpoConfig.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/ExpoConfig.ts",
        "default": "./build/ExpoConfig.d.ts"
      },
      "expo-source": "./src/ExpoConfig.ts",
      "default": "./build/ExpoConfig.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "generate": "node ./scripts/generate.js",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "prepublishOnly": "expo-module prepublishOnly",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "expo-module-scripts": "workspace:*",
    "json-schema-to-typescript": "^15.0.0",
    "prettier": "^3.8.3",
    "semver": "^7.7.4"
  }
}
