{
  "name": "expo-linking",
  "version": "56.0.12",
  "description": "Create and open deep links universally",
  "keywords": [
    "expo",
    "expo-linking",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/linking",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-linking"
  },
  "main": "build/Linking.js",
  "types": "build/Linking.d.ts",
  "exports": {
    ".": {
      "react-server": {
        "types": {
          "expo-source": "./src/Linking.server.ts",
          "default": "./build/Linking.server.js"
        },
        "expo-source": "./src/Linking.server.ts",
        "default": "./build/Linking.server.js"
      },
      "types": {
        "expo-source": "./src/Linking.ts",
        "default": "./build/Linking.d.ts"
      },
      "expo-source": "./src/Linking.ts",
      "default": "./build/Linking.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "pnpm clean && turbo run build",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "expo-constants": "workspace:~56.0.16",
    "invariant": "^2.2.4"
  },
  "devDependencies": {
    "@types/invariant": "^2.2.33",
    "@types/react": "~19.2.0",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
