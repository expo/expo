{
  "name": "expo-linking",
  "version": "55.0.7",
  "description": "Create and open deep links universally",
  "main": "build/Linking.js",
  "types": "build/Linking.d.ts",
  "exports": {
    ".": {
      "react-server": {
        "types": {
          "source": "./src/Linking.server.ts",
          "default": "./build/Linking.server.js"
        },
        "source": "./src/Linking.server.ts",
        "default": "./build/Linking.server.js"
      },
      "types": {
        "source": "./src/Linking.ts",
        "default": "./build/Linking.d.ts"
      },
      "source": "./src/Linking.ts",
      "default": "./build/Linking.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "test:rsc": "jest --config jest-rsc.config.js",
    "prepublishOnly": "expo-module prepublishOnly"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-linking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-linking"
  },
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "homepage": "https://docs.expo.dev/versions/latest/sdk/linking",
  "dependencies": {
    "expo-constants": "workspace:~55.0.7",
    "invariant": "^2.2.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "@types/invariant": "^2.2.33",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
