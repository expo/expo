{
  "name": "expo-live-photo",
  "title": "Expo Video",
  "version": "56.0.3",
  "description": "Library, which makes it possible to display live photos on iOS",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "homepage": "https://docs.expo.dev/versions/latest/sdk/live-photo/",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-live-photo"
  },
  "keywords": [
    "react-native",
    "expo",
    "live-photo",
    "photo",
    "live"
  ],
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/react": "~19.2.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
