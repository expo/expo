{
  "name": "expo-print",
  "version": "56.0.3",
  "description": "Provides an API for Android and iOS (AirPrint) printing functionality.",
  "keywords": [
    "airprint",
    "android",
    "expo",
    "ios",
    "print",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/print/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-print"
  },
  "sideEffects": false,
  "main": "build/Print.js",
  "types": "build/Print.d.ts",
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
