{
  "name": "expo-server",
  "version": "56.0.4",
  "description": "Server API for Expo Router projects",
  "keywords": [
    "expo"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo-server#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-server"
  },
  "files": [
    "build",
    "adapter"
  ],
  "sideEffects": false,
  "main": "build/cjs/index.js",
  "module": "build/mjs/index.js",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/cjs/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "import": "./build/mjs/index.js",
      "require": "./build/cjs/index.js"
    },
    "./private": {
      "types": {
        "expo-source": "./src/private.ts",
        "default": "./build/cjs/private.d.ts"
      },
      "expo-source": "./src/private.ts",
      "import": "./build/mjs/private.js",
      "require": "./build/cjs/private.js"
    },
    "./adapter/*": {
      "types": {
        "expo-source": "./src/vendor/*.ts",
        "default": "./build/cjs/vendor/*.d.ts"
      },
      "expo-source": "./src/vendor/*.ts",
      "import": "./build/mjs/vendor/*.js",
      "require": "./build/cjs/vendor/*.js"
    },
    "./vendor/*": {
      "types": {
        "expo-source": "./src/vendor/*.ts",
        "default": "./build/cjs/vendor/*.d.ts"
      },
      "expo-source": "./src/vendor/*.ts",
      "import": "./build/mjs/vendor/*.js",
      "require": "./build/cjs/vendor/*.js"
    },
    "./runtime/*": {
      "types": {
        "expo-source": "./src/runtime/*.ts",
        "default": "./build/cjs/runtime/*.d.ts"
      },
      "expo-source": "./src/runtime/*.ts",
      "import": "./build/mjs/runtime/index.js",
      "require": "./build/cjs/runtime/index.js"
    },
    "./build/*": {
      "types": {
        "expo-source": "./src/*.ts",
        "default": "./build/cjs/*.d.ts"
      },
      "expo-source": "./src/*.ts",
      "import": "./build/mjs/*.js",
      "require": "./build/cjs/*.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "expo-build cjs:src=build/cjs src=build/mjs",
    "clean": "rimraf build",
    "prepublishOnly": "run-s clean build",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/react": "~19.2.0",
    "expo-module-scripts": "workspace:*",
    "npm-run-all2": "^8.0.4",
    "rimraf": "^6.1.2"
  },
  "engines": {
    "node": "^22.13.0 || ^24.3.0 || ^26.0.0 || >=27.0.0"
  }
}
