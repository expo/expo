{
  "extends": "expo-module-scripts/tsconfig.node",
  "include": ["./src"],
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "rootDir": "./src",
    "declaration": false,
    // The preset's setup files reach into web-targeting dependency source (e.g. expo-modules-core),
    // so the DOM lib is required alongside the node defaults.
    "lib": ["es2023", "dom"]
  }
}
