{
  "name": "expo-background-fetch",
  "version": "56.0.15",
  "description": "Expo universal module for BackgroundFetch API",
  "keywords": [
    "background",
    "background-fetch",
    "expo",
    "fetch",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/background-fetch/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-background-fetch"
  },
  "sideEffects": false,
  "main": "build/BackgroundFetch.js",
  "types": "build/BackgroundFetch.d.ts",
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -b tsconfig.all.json"
  },
  "dependencies": {
    "expo-task-manager": "workspace:~56.0.15"
  },
  "devDependencies": {
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*"
  }
}
