{
  "name": "expo-widgets",
  "version": "56.0.15",
  "description": "Widgets.",
  "keywords": [
    "expo",
    "expo-widgets",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/widgets/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-widgets"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "publishConfig": {
    "executableFiles": [
      "./scripts/with-node.sh",
      "./scripts/xcode-build-bundle.sh"
    ]
  },
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "build:bundle": "node ./scripts/build-bundle.mjs",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -b tsconfig.all.json"
  },
  "dependencies": {
    "@expo/plist": "workspace:^0.7.0",
    "@expo/ui": "workspace:~56.0.14"
  },
  "devDependencies": {
    "@expo/spawn-async": "^1.8.0",
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*",
    "react-native": "0.86.0",
    "resolve-workspace-root": "^2.0.0"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
