{
  "name": "expo-crypto",
  "version": "56.0.4",
  "description": "Provides cryptography primitives for Android, iOS and web.",
  "main": "build/Crypto.js",
  "types": "build/Crypto.d.ts",
  "exports": {
    ".": {
      "types": {
        "source": "./src/Crypto.ts",
        "default": "./build/Crypto.d.ts"
      },
      "source": "./src/Crypto.ts",
      "default": "./build/Crypto.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepublishOnly": "expo-module prepublishOnly",
    "typecheck": "tsc -p tsconfig.json"
  },
  "keywords": [
    "react-native",
    "react-native-web",
    "expo",
    "crypto",
    "ios",
    "android",
    "web",
    "native"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-crypto"
  },
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "homepage": "https://docs.expo.dev/versions/latest/sdk/crypto/",
  "jest": {
    "preset": "expo-module-scripts"
  },
  "dependencies": {},
  "devDependencies": {
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*"
  }
}
