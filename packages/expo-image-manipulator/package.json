{
  "name": "expo-image-manipulator",
  "version": "56.0.15",
  "description": "Provides functions that let you manipulation images on the local file system, eg: resize, crop.",
  "keywords": [
    "expo",
    "expo-image-manipulator",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/imagemanipulator/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-image-manipulator"
  },
  "sideEffects": false,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "expo-source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "pnpm clean && turbo run build",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "expo-image-loader": "workspace:~56.0.3"
  },
  "devDependencies": {
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
