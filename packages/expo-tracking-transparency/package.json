{
  "name": "expo-tracking-transparency",
  "version": "56.0.5",
  "description": "A library for tracking app users and managing tracking permissions",
  "keywords": [
    "expo",
    "expo-tracking-transparency",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/tracking-transparency",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-tracking-transparency"
  },
  "main": "build/TrackingTransparency.js",
  "types": "build/TrackingTransparency.d.ts",
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -b tsconfig.all.json"
  },
  "devDependencies": {
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "react-native": "*"
  }
}
