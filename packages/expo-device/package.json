{
  "name": "expo-device",
  "version": "56.0.4",
  "description": "A universal module that gets physical information about the device running the application",
  "keywords": [
    "expo",
    "expo-device",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/device/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-device"
  },
  "main": "build/Device.js",
  "types": "build/Device.d.ts",
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "ua-parser-js": "^0.7.33"
  },
  "devDependencies": {
    "@types/ua-parser-js": "^0.7.39",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
