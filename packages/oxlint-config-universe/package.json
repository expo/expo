{
  "name": "oxlint-config-universe",
  "version": "0.0.1",
  "description": "Shared oxlint configs for internal Expo projects.",
  "keywords": [
    "expo",
    "oxlint",
    "oxlint-config",
    "react-native"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/oxlint-config-universe",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "Expo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/expo/expo.git",
    "directory": "packages/oxlint-config-universe"
  },
  "files": [
    "README.md",
    "index.js",
    "index.d.ts",
    "default.js",
    "default.d.ts",
    "native.js",
    "native.d.ts",
    "node.js",
    "node.d.ts",
    "web.js",
    "web.d.ts",
    "shared",
    "!**/__tests__/**"
  ],
  "type": "module",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./default": {
      "types": "./default.d.ts",
      "default": "./default.js"
    },
    "./native": {
      "types": "./native.d.ts",
      "default": "./native.js"
    },
    "./node": {
      "types": "./node.d.ts",
      "default": "./node.js"
    },
    "./web": {
      "types": "./web.d.ts",
      "default": "./web.js"
    },
    "./typescript-analysis": {
      "types": "./shared/typescript-analysis.d.ts",
      "default": "./shared/typescript-analysis.js"
    }
  },
  "scripts": {
    "format": "oxfmt --write .",
    "lint": "oxlint . -c oxlint.config.js",
    "test": "jest"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/*-test.js"
    ]
  },
  "devDependencies": {
    "@expo/spawn-async": "^1.7.2",
    "@oxfmt/binding-darwin-arm64": "^0.44.0",
    "@oxlint/binding-darwin-arm64": "^1.59.0",
    "jest": "^29.7.0",
    "glob": "^13.0.6",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  },
  "peerDependencies": {
    "oxlint": ">=1.59.0"
  },
  "volta": {
    "node": "22.18.0"
  },
  "pnpm": {
    "executionEnv": {
      "nodeVersion": "22.18.0"
    }
  }
}
