{
  "name": "expo-clipboard",
  "version": "56.0.3",
  "description": "Provides an interface for getting and setting Clipboard content on Android, iOS, macOS and Web.",
  "keywords": [
    "expo",
    "expo-clipboard",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/clipboard",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-clipboard"
  },
  "main": "build/Clipboard.js",
  "types": "build/Clipboard.d.ts",
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "pnpm clean && turbo run build",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "~19.2.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "expo-module-scripts/universal"
  }
}
