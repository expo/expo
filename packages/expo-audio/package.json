{
  "name": "expo-audio",
  "title": "Expo Audio",
  "version": "56.0.11",
  "description": "A cross-platform audio library for React Native and Expo apps.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -b tsconfig.all.json"
  },
  "homepage": "https://docs.expo.dev/versions/latest/sdk/audio/",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-audio"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-audio",
    "audio",
    "ios",
    "android"
  ],
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "expo": "workspace:*",
    "expo-asset": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "expo-asset": "*",
    "react": "*",
    "react-native": "*"
  }
}
