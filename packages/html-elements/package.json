{
  "name": "@expo/html-elements",
  "version": "56.0.1",
  "description": "Universal semantic HTML React components for iOS, Android, web, and desktop",
  "keywords": [
    "expo",
    "expo-web",
    "html",
    "react-native",
    "react-native-web"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/html-elements",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/html-elements"
  },
  "sideEffects": false,
  "main": "build/Elements.js",
  "types": "build/Elements.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/Elements.tsx",
        "default": "./build/Elements.d.ts"
      },
      "expo-source": "./src/Elements.tsx",
      "default": "./build/Elements.js"
    },
    "./primitives/*": {
      "types": {
        "expo-source": "./src/primitives/*.tsx",
        "default": "./build/primitives/*.d.ts"
      },
      "expo-source": "./src/primitives/*.tsx",
      "default": "./build/primitives/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "pnpm test:babel && pnpm test:src",
    "test:src": "jest",
    "test:babel": "jest --config babel/jest.config.js",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^13.3.0",
    "@types/react": "~19.2.2",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-web": "*"
  },
  "peerDependenciesMeta": {
    "react-native-web": {
      "optional": true
    }
  },
  "jest": {
    "projects": [
      {
        "preset": "jest-expo/web",
        "setupFilesAfterEnv": [
          "<rootDir>/jest-setup.js"
        ],
        "modulePathIgnorePatterns": [
          "<rootDir>/babel/"
        ]
      },
      {
        "preset": "jest-expo/ios",
        "modulePathIgnorePatterns": [
          "<rootDir>/babel/"
        ]
      },
      {
        "preset": "jest-expo/android",
        "modulePathIgnorePatterns": [
          "<rootDir>/babel/"
        ]
      }
    ]
  }
}
