{
  "name": "expo-env-info",
  "version": "2.0.14",
  "description": "Fetch Expo project information for GitHub issue diagnostics",
  "keywords": [
    "android",
    "expo",
    "expo-env-info",
    "ios"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo-env-info#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "Expo <support@expo.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-env-info"
  },
  "bin": "./bin/expo-env-info.js",
  "files": [
    "bin",
    "build"
  ],
  "main": "./build/main.js",
  "scripts": {
    "build": "ncc build ./src/index.ts -o build/",
    "build:prod": "ncc build ./src/index.ts -o build/ --minify --no-cache --no-source-map-register",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "prepublishOnly": "pnpm run clean && pnpm run build:prod",
    "test": "jest",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "envinfo": "^7.8.1"
  },
  "devDependencies": {
    "@types/envinfo": "^7.8.1",
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0"
  },
  "preferGlobal": true,
  "engines": {
    "node": "^12.20.0 || ^14.13.1 || >=16.0.0"
  }
}
