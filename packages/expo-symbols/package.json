{
  "name": "expo-symbols",
  "version": "55.0.4",
  "description": "Provides access to the SF Symbols library on iOS, and Material Symbols on Android and web, for Expo and React Native apps.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.ts",
        "default": "./build/index.d.ts"
      },
      "source": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./androidWeights/*": {
      "types": {
        "source": "./src/android/weights/*/index.ts",
        "default": "./build/android/weights/*/index.d.ts"
      },
      "source": "./src/android/weights/*/index.ts",
      "default": "./build/android/weights/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "prepublishOnly": "expo-module prepublishOnly"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-symbols",
    "symbols",
    "sfsymbols",
    "ios"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-symbols"
  },
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "homepage": "https://docs.expo.dev/versions/latest/sdk/symbols/",
  "dependencies": {
    "sf-symbols-typescript": "^2.0.0",
    "@expo-google-fonts/material-symbols": "^0.4.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.0",
    "expo-module-scripts": "workspace:*",
    "expo-font": "workspace:*"
  },
  "peerDependencies": {
    "expo": "workspace:*",
    "react": "*",
    "react-native": "*",
    "expo-font": "workspace:*"
  }
}
