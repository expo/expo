{
  "extends": "expo-module-scripts/tsconfig.base",
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./src",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "resolveJsonModule": true,
    "types": ["jest", "node"],

    // TODO: Enable in the future
    "noUncheckedIndexedAccess": false
  },
  "include": ["./src"],
  "exclude": ["**/__tests__/", "**/__rsc_tests__/"]
}
