{
  "extends": "expo-module-scripts/tsconfig.base",
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./src",
    "noEmit": false,
    "resolveJsonModule": true,
    "types": ["jest", "node", "../@expo/cli/ts-declarations/react-server-dom-webpack"],

    // TODO: Enable in the future
    "noUncheckedIndexedAccess": false
  },
  "include": ["./src"],
  "exclude": ["**/__tests__/", "**/__rsc_tests__/"]
}
