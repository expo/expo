{
  "name": "expo-router",
  "version": "55.0.2",
  "description": "Expo Router is a file-based router for React Native and web applications.",
  "author": "650 Industries, Inc.",
  "license": "MIT",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "source": "./src/index.tsx",
        "default": "./build/index.d.ts"
      },
      "source": "./src/index.tsx",
      "default": "./build/index.js"
    },
    "./internal/*": {
      "types": {
        "source": "./src/internal/*.ts",
        "default": "./build/internal/*.d.ts"
      },
      "source": "./src/internal/*.ts",
      "default": "./build/internal/*.js"
    },
    "./build/Route": {
      "types": {
        "source": "./src/Route.tsx",
        "default": "./build/Route.d.ts"
      },
      "source": "./src/Route.ts",
      "default": "./build/Route.js"
    },
    "./build/matchers": {
      "types": {
        "source": "./src/matchers.tsx",
        "default": "./build/matchers.d.ts"
      },
      "source": "./src/matchers.ts",
      "default": "./build/matchers.js"
    },
    "./build/*.js": {
      "types": {
        "source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./build/*": {
      "types": {
        "source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./drawer": {
      "types": {
        "source": "./src/layouts/Drawer.tsx",
        "default": "./build/layouts/Drawer.d.ts"
      },
      "source": "./src/layouts/Drawer.tsx",
      "default": "./build/layouts/Drawer.js"
    },
    "./head": {
      "types": {
        "source": "./src/head/ExpoHead.tsx",
        "default": "./build/head/ExpoHead.d.ts"
      },
      "source": "./src/head/ExpoHead.tsx",
      "default": "./build/head/ExpoHead.js"
    },
    "./html": {
      "types": {
        "source": "./src/static/html.tsx",
        "default": "./build/static/html.d.ts"
      },
      "source": "./src/static/html.tsx",
      "default": "./build/static/html.js"
    },
    "./js-stack": {
      "types": {
        "source": "./src/layouts/JSStack.tsx",
        "default": "./build/layouts/JSStack.d.ts"
      },
      "source": "./src/layouts/JSStack.tsx",
      "default": "./build/layouts/JSStack.js"
    },
    "./js-tabs": {
      "types": {
        "source": "./src/layouts/Tabs.tsx",
        "default": "./build/layouts/Tabs.d.ts"
      },
      "source": "./src/layouts/Tabs.tsx",
      "default": "./build/layouts/Tabs.js"
    },
    "./js-top-tabs": {
      "types": {
        "source": "./src/layouts/TopTabs.tsx",
        "default": "./build/layouts/TopTabs.d.ts"
      },
      "source": "./src/layouts/TopTabs.tsx",
      "default": "./build/layouts/TopTabs.js"
    },
    "./stack": {
      "types": {
        "source": "./src/layouts/Stack.tsx",
        "default": "./build/layouts/Stack.d.ts"
      },
      "source": "./src/layouts/Stack.tsx",
      "default": "./build/layouts/Stack.js"
    },
    "./tabs": {
      "types": {
        "source": "./src/layouts/Tabs.tsx",
        "default": "./build/layouts/Tabs.d.ts"
      },
      "source": "./src/layouts/Tabs.tsx",
      "default": "./build/layouts/Tabs.js"
    },
    "./testing-library": {
      "types": {
        "source": "./src/testing-library/index.tsx",
        "default": "./build/testing-library/index.d.ts"
      },
      "source": "./src/testing-library/index.tsx",
      "default": "./build/testing-library/index.js"
    },
    "./ui": {
      "types": {
        "source": "./src/ui/index.ts",
        "default": "./build/ui/index.d.ts"
      },
      "source": "./src/ui/index.ts",
      "default": "./build/ui/index.js"
    },
    "./unstable-native-tabs": {
      "types": {
        "source": "./src/native-tabs/index.ts",
        "default": "./build/native-tabs/index.d.ts"
      },
      "source": "./src/native-tabs/index.ts",
      "default": "./build/native-tabs/index.js"
    },
    "./split-view": {
      "types": {
        "source": "./src/split-view/index.ts",
        "default": "./build/split-view/index.d.ts"
      },
      "source": "./src/split-view/index.ts",
      "default": "./build/split-view/index.js"
    },
    "./rsc": {
      "types": {
        "source": "./src/rsc/exports.ts",
        "default": "./build/rsc/exports.d.ts"
      },
      "source": "./src/rsc/exports.ts",
      "default": "./build/rsc/exports.js"
    },
    "./rsc/internal": {
      "types": {
        "source": "./src/rsc/router/host.tsx",
        "default": "./build/rsc/router/host.d.ts"
      },
      "source": "./src/rsc/router/host.tsx",
      "default": "./build/rsc/router/host.js"
    },
    "./link": {
      "types": "./link/index.d.ts",
      "default": "./link/index.js"
    },
    "./rsc/headers": {
      "types": "./rsc/headers.d.ts",
      "default": "./rsc/headers.js"
    },
    "./rsc/headers.js": {
      "types": "./rsc/headers.d.ts",
      "default": "./rsc/headers.js"
    },
    "./_ctx-html": "./_ctx-html.js",
    "./_ctx-shared": "./_ctx-shared.js",
    "./_ctx": {
      "types": "./_ctx.d.ts",
      "default": "./_ctx.js"
    },
    "./_error.js": "./_error.js",
    "./entry-classic.js": "./entry-classic.js",
    "./entry-classic": "./entry-classic.js",
    "./entry.js": "./entry.js",
    "./entry": "./entry.js",
    "./rsc/entry": "./rsc/entry.js",
    "./rsc/entry.js": "./rsc/entry.js",
    "./assets/*": "./assets/*",
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "rsc/entry.js",
    "entry-classic.js",
    "entry.js"
  ],
  "files": [
    "link",
    "android",
    "local-maven-repo",
    "assets",
    "build",
    "internal",
    "vendor",
    "!src",
    "_ctx-html.js",
    "_ctx-shared.js",
    "_ctx.*",
    "_error.js",
    "app.plugin.js",
    "babel.js",
    "drawer.d.ts",
    "drawer.js",
    "entry-classic.js",
    "entry.js",
    "expo-module.config.json",
    "head.d.ts",
    "head.js",
    "html.d.ts",
    "html.js",
    "index.d.ts",
    "ios",
    "unstable-native-tabs.js",
    "unstable-native-tabs.d.ts",
    "unstable-split-view.js",
    "unstable-split-view.d.ts",
    "node",
    "plugin",
    "rsc",
    "server.d.ts",
    "server.js",
    "stack.d.ts",
    "stack.js",
    "js-tabs.js",
    "js-tabs.d.ts",
    "js-stack.js",
    "js-stack.d.ts",
    "js-top-tabs.js",
    "js-top-tabs.d.ts",
    "tabs.js",
    "tabs.d.ts",
    "ui.js",
    "ui.d.ts",
    "testing-library.js",
    "testing-library.d.ts",
    "_async-server-import.js"
  ],
  "repository": {
    "url": "https://github.com/expo/expo.git",
    "type": "git",
    "directory": "packages/expo-router"
  },
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "homepage": "https://docs.expo.dev/routing/introduction/",
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build cjs:src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "expo-module test",
    "test:rsc": "jest --config jest-rsc.config.js",
    "test:types": "expo-module build -p tsconfig.test.json",
    "prepublishOnly": "expo-module prepublishOnly",
    "expo-module": "expo-module"
  },
  "keywords": [
    "react-native",
    "expo"
  ],
  "peerDependencies": {
    "@expo/log-box": "workspace:55.0.7",
    "@expo/metro-runtime": "workspace:^55.0.6",
    "@testing-library/react-native": ">= 13.2.0",
    "expo": "workspace:*",
    "expo-constants": "workspace:^55.0.7",
    "expo-linking": "workspace:^55.0.7",
    "react": "*",
    "react-dom": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": ">= 5.4.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "*",
    "react-server-dom-webpack": "~19.0.4 || ~19.1.5 || ~19.2.4"
  },
  "peerDependenciesMeta": {
    "@testing-library/react-native": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    },
    "react-server-dom-webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^13.3.0",
    "@tsd/typescript": "^5.9.3",
    "@types/color": "^4.2.0",
    "@types/debug": "^4.1.7",
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "@types/react-dom": "^19.1.7",
    "@types/react-is": "^19.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "immer": "^10.1.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.24.0",
    "react-native-web": "~0.21.0",
    "react-server-dom-webpack": "~19.0.4",
    "tsd": "^0.33.0"
  },
  "dependencies": {
    "@expo/metro-runtime": "workspace:^55.0.6",
    "@expo/schema-utils": "workspace:^55.0.2",
    "@expo/ui": "workspace:^55.0.0",
    "@jest/globals": "^29.7.0",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.12",
    "@react-native-masked-view/masked-view": "^0.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "client-only": "^0.0.1",
    "color": "^4.2.3",
    "debug": "^4.3.4",
    "escape-string-regexp": "^4.0.0",
    "expo-glass-effect": "workspace:^55.0.7",
    "expo-image": "workspace:^55.0.5",
    "expo-server": "workspace:^55.0.5",
    "expo-symbols": "workspace:^55.0.4",
    "fast-deep-equal": "^3.1.3",
    "invariant": "^2.2.4",
    "nanoid": "^3.3.8",
    "query-string": "^7.1.3",
    "react-fast-compare": "^3.2.2",
    "react-is": "^19.1.0",
    "react-native-drawer-layout": "^4.2.2",
    "react-native-screens": "~4.24.0",
    "server-only": "^0.0.1",
    "sf-symbols-typescript": "^2.1.0",
    "shallowequal": "^1.1.0",
    "vaul": "^1.1.2"
  }
}
