{
  "name": "expo-apple-authentication",
  "version": "56.0.4",
  "description": "A package that provides 'Sign in with Apple' capability for Expo and React Native apps.",
  "keywords": [
    "apple-authentication",
    "expo",
    "expo-apple-authentiocation",
    "react-native",
    "sign-in-with-apple"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/apple-authentication/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-apple-authentication"
  },
  "sideEffects": false,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "pnpm run build:lib && pnpm run build:plugin",
    "build:lib": "expo-build src",
    "build:plugin": "expo-build --base plugin cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "oxfmt .",
    "prepublishOnly": "expo-module prepublishOnly",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -b tsconfig.all.json"
  },
  "devDependencies": {
    "@types/jest": "^29.2.1",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  }
}
