{
  "name": "expo-constants",
  "version": "56.0.16",
  "description": "Provides system information that remains constant throughout the lifetime of your app.",
  "keywords": [
    "constants",
    "expo",
    "react-native"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/constants/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-constants"
  },
  "sideEffects": false,
  "main": "build/Constants.js",
  "types": "build/Constants.d.ts",
  "exports": {
    ".": {
      "react-server": {
        "types": {
          "expo-source": "./src/Constants.server.ts",
          "default": "./build/Constants.server.d.ts"
        },
        "expo-source": "./src/Constants.server.ts",
        "default": "./build/Constants.server.js"
      },
      "types": {
        "expo-source": "./src/Constants.ts",
        "default": "./build/Constants.d.ts"
      },
      "expo-source": "./src/Constants.ts",
      "default": "./build/Constants.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "executableFiles": [
      "./scripts/get-app-config-ios.sh",
      "./scripts/with-node.sh"
    ]
  },
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "pnpm clean && turbo run build",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@expo/env": "workspace:~2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "expo-manifests": "workspace:*",
    "expo-module-scripts": "workspace:*",
    "expo-updates": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*",
    "react-native": "*"
  }
}
