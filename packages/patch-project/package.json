{
  "name": "patch-project",
  "version": "56.0.16",
  "description": "An Expo config-plugin and tool to support patch-based CNG",
  "keywords": [
    "cng",
    "expo",
    "patch",
    "prebuild",
    "project"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/patch-project#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/patch-project"
  },
  "bin": {
    "patch-project": "bin/cli.js"
  },
  "files": [
    "app.plugin.js",
    "bin",
    "build"
  ],
  "main": "build/withPatchPlugin.js",
  "types": "build/withPatchPlugin.d.ts",
  "scripts": {
    "build": "expo-build cjs:src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "jest",
    "pretest:e2e": "pnpm run build",
    "test:e2e": "jest --config e2e/jest.config.js",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@bacons/xcode": "1.0.0-alpha.24",
    "@expo/config": "workspace:~56.0.9",
    "@expo/config-plugins": "workspace:~56.0.8",
    "@expo/env": "workspace:~2.3.0",
    "@expo/spawn-async": "^1.8.0",
    "arg": "5.0.2",
    "chalk": "^4.0.0",
    "debug": "^4.3.1",
    "getenv": "^2.0.0",
    "glob": "^13.0.0",
    "resolve-from": "^5.0.0"
  },
  "devDependencies": {
    "@expo/cli": "workspace:*",
    "@types/debug": "^4.1.5",
    "@types/getenv": "^1.0.0",
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*",
    "memfs": "^3.2.0"
  },
  "peerDependencies": {
    "expo": "*"
  }
}
