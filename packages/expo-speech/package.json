{
  "name": "expo-speech",
  "version": "56.0.3",
  "description": "Provides text-to-speech functionality.",
  "keywords": [
    "expo",
    "expo-speech",
    "react-native",
    "speech",
    "voice"
  ],
  "homepage": "https://docs.expo.dev/versions/latest/sdk/speech/",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "650 Industries, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo-speech"
  },
  "sideEffects": false,
  "main": "build/Speech.js",
  "types": "build/Speech.d.ts",
  "scripts": {
    "build": "expo-build src",
    "clean": "expo-module clean",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest",
    "prepublishOnly": "pnpm clean && turbo run build",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "expo": "workspace:*",
    "expo-module-scripts": "workspace:*"
  },
  "peerDependencies": {
    "expo": "*"
  },
  "jest": {
    "preset": "expo-module-scripts"
  }
}
