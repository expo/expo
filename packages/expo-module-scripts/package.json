{
  "name": "expo-module-scripts",
  "version": "56.0.2",
  "description": "A private package for various tasks for Expo module packages like compiling and testing",
  "keywords": [
    "babel-preset",
    "expo",
    "jest-preset"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo-module-scripts#readme",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "Expo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/expo/expo.git",
    "directory": "packages/expo-module-scripts"
  },
  "bin": {
    "expo-build": "bin/expo-build",
    "expo-module": "bin/expo-module.js"
  },
  "type": "module",
  "main": "index.js",
  "exports": {
    "./package.json": "./package.json",
    "./oxlint.config.base": {
      "import": "./oxlint.config.base.js"
    },
    "./oxlint.config.base.js": {
      "import": "./oxlint.config.base.js"
    },
    "./jest-preset-*": {
      "import": "./jest-preset-*.cjs",
      "require": "./jest-preset-*.cjs"
    },
    "./jest-preset-*.js": {
      "import": "./jest-preset-*.cjs",
      "require": "./jest-preset-*.cjs"
    },
    "./jest-preset": {
      "import": "./jest-preset.cjs",
      "require": "./jest-preset.cjs"
    },
    "./createJestPreset": {
      "import": "./createJestPreset.cjs",
      "require": "./createJestPreset.cjs"
    },
    "./createCompositeJestPreset": {
      "import": "./createCompositeJestPreset.cjs",
      "require": "./createCompositeJestPreset.cjs"
    },
    "./jest-preset.js": {
      "import": "./jest-preset.cjs",
      "require": "./jest-preset.cjs"
    },
    "./*/jest-preset": {
      "import": "./*/jest-preset.cjs",
      "require": "./*/jest-preset.cjs"
    },
    "./*/jest-preset.js": {
      "import": "./*/jest-preset.cjs",
      "require": "./*/jest-preset.cjs"
    },
    "./types/*": "./types/*",
    "./tsconfig.*": "./tsconfig.*.json",
    "./tsconfig": "./tsconfig.json"
  },
  "publishConfig": {
    "executableFiles": [
      "./bin/expo-module-build",
      "./bin/expo-module-clean",
      "./bin/expo-module-configure",
      "./bin/expo-module-depscheck",
      "./bin/expo-module-format",
      "./bin/expo-module-jest",
      "./bin/expo-module-prepare",
      "./bin/expo-module-prepublishOnly",
      "./bin/expo-module-readme",
      "./bin/expo-module-test",
      "./bin/expo-module-tsc",
      "./bin/expo-module-typecheck",
      "./bin/expo-module.js"
    ]
  },
  "scripts": {
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@expo/spawn-async": "^1.8.0",
    "@react-native/jest-preset": "0.87.0-rc.0",
    "@swc-contrib/mut-cjs-exports": "^14.13.0",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@testing-library/react-native": "^13.3.0",
    "@types/jest": "^29.2.1",
    "commander": "^12.1.0",
    "glob": "^13.0.0",
    "jest-expo": "workspace:~56.0.4",
    "jest-snapshot-prettier": "npm:prettier@^2",
    "jest-watch-typeahead": "2.2.1",
    "oxlint-config-universe": "^0.0.3",
    "resolve-workspace-root": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@expo/metro": "~56.0.0"
  }
}
