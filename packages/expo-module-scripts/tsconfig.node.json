{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "${configDir}",

    "lib": ["es2023"],
    "target": "es2022",
    "declarationMap": false,
    "inlineSources": false,
    "resolveJsonModule": true,

    // TODO(@kitten): Update accordingly when tsc isn't used to build outputs anymore at all
    "module": "nodenext",
    "moduleResolution": "node16",
    "verbatimModuleSyntax": false
  }
}
