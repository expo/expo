#!/usr/bin/env node

import fs from 'node:fs';
import path from 'node:path';
import { commandRunner, getArgs } from '../utils/commandUtils.js';
import { fileURLToPath } from 'node:url';

const dirname = path.dirname(fileURLToPath(import.meta.url));

const EXTRA_MODULE_BUILD_TARGETS = ['plugin', 'cli', 'utils', 'scripts', 'shared'];

let args = getArgs();

// If the command is used like `yarn lint plugin` then set the target to `plugin/src`
if (EXTRA_MODULE_BUILD_TARGETS.includes(args[0])) {
  // Push the rest of the arguments minus the `plugin` arg
  const target = args[0];
  args = [...args.slice(1), `${target}/src`];
} else {
  // By default, lint `src` plus each build sub-target's `src` (e.g. `plugin/src`, `cli/src`)
  // that exists, so a single `lint` task covers the whole package in one ESLint invocation.
  // Mirrors the composite `test` task that runs every sub-folder's tests at once.
  const cwd = process.cwd();
  const targets = ['src'];
  for (const target of EXTRA_MODULE_BUILD_TARGETS) {
    if (fs.existsSync(path.join(cwd, target, 'src'))) {
      targets.push(`${target}/src`);
    }
  }
  args = [...args, ...targets];
}

await commandRunner(path.join(dirname, 'expo-module-eslint'), args);
