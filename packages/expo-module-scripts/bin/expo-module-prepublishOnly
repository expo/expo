#!/usr/bin/env node

process.env.EXPO_NONINTERACTIVE = 1;

// Intentionally a no-op. Packages are built ahead of publishing by Turborepo (`turbo build`,
// run via the `prepare` hook on `pnpm install` and by the publish pipeline), so there is nothing
// to do here. This used to run `expo-module-clean` + `expo-module-build`, but packages now build
// with the SWC-based `expo-build` and set `noEmit: true` in their `tsconfig.json` (tsc is only
// used for type-checking) — so the tsc-based `expo-module-build` emitted nothing and the clean
// left an empty `build/` to be published.
async function runAsync() {}

(async () => {
  try {
    await runAsync();
  } catch (error) {
    console.error(error);
    process.exit(error.status || error.code || 1);
  }
})();
