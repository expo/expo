{
  "name": "expo",
  "version": "56.0.5",
  "description": "The Expo SDK",
  "keywords": [
    "expo"
  ],
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "license": "MIT",
  "author": "Expo",
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo"
  },
  "bin": {
    "expo": "bin/cli",
    "expo-modules-autolinking": "bin/autolinking",
    "fingerprint": "bin/fingerprint"
  },
  "files": [
    "android",
    "bin",
    "build",
    "internal",
    "ios",
    "scripts",
    "src",
    "AppEntry.js",
    "Expo.podspec",
    "bundledNativeModules.json",
    "expo-module.config.json",
    "metro-config.js",
    "metro-config.d.ts",
    "dom",
    "config",
    "config-plugins.js",
    "config-plugins.d.ts",
    "devtools.js",
    "devtools.d.ts",
    "fetch.js",
    "fetch.d.ts",
    "fingerprint.js",
    "fingerprint.d.ts",
    "local-build-cache-provider.js",
    "local-build-cache-provider.d.ts",
    "react-native.config.js",
    "requiresExtraSetup.json",
    "tsconfig.base.json",
    "types",
    "virtual",
    "template.tgz"
  ],
  "sideEffects": [
    "*.fx.tsx",
    "*.fx.web.tsx",
    "*.fx.js",
    "*.fx.web.js",
    "./src/winter/*.ts",
    "./build/winter/*.js",
    "./src/async-require/*.ts",
    "./build/async-require/*.js"
  ],
  "main": "build/Expo.js",
  "module": "build/Expo.js",
  "types": "build/Expo.d.ts",
  "exports": {
    ".": {
      "types": {
        "expo-source": "./src/Expo.ts",
        "default": "./build/Expo.d.ts"
      },
      "expo-source": "./src/Expo.ts",
      "default": "./build/Expo.js"
    },
    "./types": {
      "types": "./types/index.d.ts",
      "default": "./types/index.js"
    },
    "./internal/async-require-module": {
      "types": {
        "expo-source": "./src/async-require/asyncRequireModule.ts",
        "default": "./build/async-require/asyncRequireModule.d.ts"
      },
      "expo-source": "./src/async-require/asyncRequireModule.ts",
      "default": "./build/async-require/asyncRequireModule.js"
    },
    "./internal/install-global": {
      "types": {
        "expo-source": "./src/winter/installGlobal.ts",
        "default": "./build/winter/installGlobal.d.ts"
      },
      "expo-source": "./src/winter/installGlobal.ts",
      "default": "./build/winter/installGlobal.js"
    },
    "./internal/*": {
      "types": "./internal/*.d.ts",
      "default": "./internal/*.js"
    },
    "./dom": {
      "types": {
        "expo-source": "./src/dom/dom.ts",
        "default": "./build/dom/dom.d.ts"
      },
      "expo-source": "./src/dom/dom.ts",
      "default": "./build/dom/dom.js"
    },
    "./dom/global": {
      "types": {
        "expo-source": "./src/dom/global-events.ts",
        "default": "./build/dom/global-events.d.ts"
      },
      "expo-source": "./src/dom/global-events.ts",
      "default": "./build/dom/global-events.js"
    },
    "./dom/internal": {
      "types": {
        "expo-source": "./src/dom/internal.ts",
        "default": "./build/dom/internal.d.ts"
      },
      "expo-source": "./src/dom/internal.ts",
      "default": "./build/dom/internal.js"
    },
    "./fetch": {
      "types": {
        "expo-source": "./src/winter/fetch/index.ts",
        "default": "./build/winter/fetch/index.d.ts"
      },
      "expo-source": "./src/winter/fetch/index.ts",
      "default": "./build/winter/fetch/index.js"
    },
    "./config": {
      "types": "./config/index.d.ts",
      "default": "./config/index.js"
    },
    "./config/paths": {
      "types": "./config/paths.d.ts",
      "default": "./config/paths.js"
    },
    "./src/winter": {
      "types": {
        "expo-source": "./src/winter/index.ts",
        "default": "./build/winter/index.d.ts"
      },
      "expo-source": "./src/winter/index.ts",
      "default": "./build/winter/index.js"
    },
    "./src/*.ts": {
      "types": {
        "expo-source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "expo-source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./src/*": {
      "types": {
        "expo-source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "expo-source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./dom/entry.js": "./dom/entry.js",
    "./dom/entry": "./dom/entry.js",
    "./AppEntry.js": "./AppEntry.js",
    "./virtual/*.js": "./virtual/*.js",
    "./virtual/*": "./virtual/*.js",
    "./scripts/*.js": "./scripts/*.js",
    "./scripts/*": "./scripts/*.js",
    "./bin/*": "./bin/*",
    "./package.json": "./package.json",
    "./*.json": "./*.json",
    "./*": {
      "types": "./*.d.ts",
      "default": "./*.js"
    }
  },
  "publishConfig": {
    "executableFiles": [
      "./scripts/node-binary.sh",
      "./scripts/react-native-xcode.sh",
      "./scripts/xcode/with-environment.sh",
      "./scripts/compose-source-maps.js",
      "./scripts/resolveAppEntry.js"
    ]
  },
  "scripts": {
    "build": "../expo-module-scripts/bin/expo-build src",
    "clean": "rimraf build",
    "lint": "oxlint --config oxlint.config.mjs .",
    "format": "expo-module format",
    "test": "jest && jest --config scripts/spm/jest.config.js",
    "test:spm-plugin": "jest --config scripts/spm/jest.config.js",
    "prepublishOnly": "run-s clean build",
    "depscheck": "expo-module depscheck",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.0",
    "@expo/cli": "workspace:^56.1.12",
    "@expo/config": "workspace:~56.0.9",
    "@expo/config-plugins": "workspace:~56.0.8",
    "@expo/devtools": "workspace:~56.0.2",
    "@expo/dom-webview": "workspace:~56.0.5",
    "@expo/fingerprint": "workspace:^0.19.3",
    "@expo/local-build-cache-provider": "workspace:^56.0.8",
    "@expo/log-box": "workspace:^56.0.12",
    "@expo/log-box-utils": "workspace:^56.0.0",
    "@expo/metro": "~56.0.0",
    "@expo/metro-config": "workspace:~56.0.13",
    "@ungap/structured-clone": "^1.3.0",
    "babel-preset-expo": "workspace:~56.0.13",
    "expo-asset": "workspace:~56.0.15",
    "expo-constants": "workspace:~56.0.16",
    "expo-file-system": "workspace:~56.0.7",
    "expo-font": "workspace:~56.0.5",
    "expo-keep-awake": "workspace:~56.0.3",
    "expo-modules-autolinking": "workspace:~56.0.13",
    "expo-modules-core": "workspace:~56.0.13",
    "pretty-format": "^29.7.0",
    "react-refresh": "^0.14.2",
    "whatwg-url-minimum": "^0.2.0"
  },
  "devDependencies": {
    "@expo/dom-webview": "workspace:*",
    "@expo/metro-runtime": "workspace:*",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "expo-updates": "workspace:*",
    "npm-run-all2": "^8.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "rimraf": "^6.1.2",
    "web-streams-polyfill": "^3.3.2"
  },
  "peerDependencies": {
    "@expo/dom-webview": "*",
    "@expo/metro-runtime": "*",
    "react": "*",
    "react-dom": "*",
    "react-native": "*",
    "react-native-web": "*",
    "react-native-webview": "*"
  },
  "peerDependenciesMeta": {
    "@expo/dom-webview": {
      "optional": true
    },
    "@expo/metro-runtime": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    }
  },
  "jest": {
    "preset": "../expo-module-scripts/jest-preset.cjs"
  },
  "engines": {
    "node": "^22.13.0 || ^24.3.0 || ^26.0.0 || >=27.0.0"
  }
}
