{
  "name": "expo",
  "version": "55.0.2",
  "description": "The Expo SDK",
  "main": "build/Expo.js",
  "module": "build/Expo.js",
  "types": "build/Expo.d.ts",
  "sideEffects": [
    "*.fx.tsx",
    "*.fx.web.tsx",
    "*.fx.js",
    "*.fx.web.js",
    "./src/winter/*.ts",
    "./build/winter/*.js",
    "./src/async-require/*.ts",
    "./build/async-require/*.js"
  ],
  "exports": {
    ".": {
      "types": {
        "source": "./src/Expo.ts",
        "default": "./build/Expo.d.ts"
      },
      "source": "./src/Expo.ts",
      "default": "./build/Expo.js"
    },
    "./types": {
      "types": "./types/index.d.ts",
      "default": "./types/index.js"
    },
    "./internal/async-require-module": {
      "types": {
        "source": "./src/async-require/asyncRequireModule.ts",
        "default": "./build/async-require/asyncRequireModule.d.ts"
      },
      "source": "./src/async-require/asyncRequireModule.ts",
      "default": "./build/async-require/asyncRequireModule.js"
    },
    "./internal/install-global": {
      "types": {
        "source": "./src/winter/installGlobal.ts",
        "default": "./build/winter/installGlobal.d.ts"
      },
      "source": "./src/winter/installGlobal.ts",
      "default": "./build/winter/installGlobal.js"
    },
    "./internal/*": {
      "types": "./internal/*.d.ts",
      "default": "./internal/*.js"
    },
    "./dom": {
      "types": {
        "source": "./src/dom/dom.ts",
        "default": "./build/dom/dom.d.ts"
      },
      "source": "./src/dom/dom.ts",
      "default": "./build/dom/dom.js"
    },
    "./dom/global": {
      "types": {
        "source": "./src/dom/global-events.ts",
        "default": "./build/dom/global-events.d.ts"
      },
      "source": "./src/dom/global-events.ts",
      "default": "./build/dom/global-events.js"
    },
    "./dom/*": {
      "types": {
        "source": "./src/dom/*.ts",
        "default": "./build/dom/*.d.ts"
      },
      "source": "./src/dom/*.ts",
      "default": "./build/dom/*.js"
    },
    "./config": {
      "types": "./config/index.d.ts",
      "default": "./config/index.js"
    },
    "./config/paths": {
      "types": "./config/paths.d.ts",
      "default": "./config/paths.js"
    },
    "./src/winter": {
      "types": {
        "source": "./src/winter/index.ts",
        "default": "./build/winter/index.d.ts"
      },
      "source": "./src/winter/index.ts",
      "default": "./build/winter/index.js"
    },
    "./src/*.ts": {
      "types": {
        "source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./src/*": {
      "types": {
        "source": "./src/*.ts",
        "default": "./build/*.d.ts"
      },
      "source": "./src/*.ts",
      "default": "./build/*.js"
    },
    "./AppEntry.js": "./AppEntry.js",
    "./virtual/*": "./virtual/*.js",
    "./scripts/*.js": "./scripts/*.js",
    "./scripts/*": "./scripts/*",
    "./bin/*": "./bin/*",
    "./package.json": "./package.json",
    "./*.json": "./*.json",
    "./*": {
      "types": "./*.d.ts",
      "default": "./*.js"
    }
  },
  "bin": {
    "expo": "bin/cli",
    "expo-modules-autolinking": "bin/autolinking",
    "fingerprint": "bin/fingerprint"
  },
  "files": [
    "android",
    "bin",
    "build",
    "internal",
    "ios",
    "scripts",
    "src",
    "AppEntry.js",
    "Expo.podspec",
    "bundledNativeModules.json",
    "expo-module.config.json",
    "metro-config.js",
    "metro-config.d.ts",
    "dom",
    "config",
    "config-plugins.js",
    "config-plugins.d.ts",
    "devtools.js",
    "devtools.d.ts",
    "fetch.js",
    "fetch.d.ts",
    "fingerprint.js",
    "fingerprint.d.ts",
    "local-build-cache-provider.js",
    "local-build-cache-provider.d.ts",
    "react-native.config.js",
    "requiresExtraSetup.json",
    "tsconfig.base.json",
    "types",
    "virtual",
    "template.tgz"
  ],
  "scripts": {
    "build": "../expo-module-scripts/bin/expo-build src",
    "clean": "rimraf build",
    "lint": "eslint src",
    "test": "jest",
    "prepublishOnly": "run-s clean build"
  },
  "jest": {
    "preset": "../expo-module-scripts/jest-preset.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/expo/expo.git",
    "directory": "packages/expo"
  },
  "keywords": [
    "expo"
  ],
  "author": "Expo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/expo/expo/issues"
  },
  "homepage": "https://github.com/expo/expo/tree/main/packages/expo",
  "dependencies": {
    "@babel/runtime": "^7.20.0",
    "@expo/cli": "workspace:55.0.12",
    "@expo/config": "workspace:~55.0.8",
    "@expo/config-plugins": "workspace:~55.0.6",
    "@expo/devtools": "workspace:55.0.2",
    "@expo/fingerprint": "workspace:0.16.5",
    "@expo/local-build-cache-provider": "workspace:55.0.6",
    "@expo/log-box": "workspace:55.0.7",
    "@expo/metro": "56.0.0-rc.0",
    "@expo/metro-config": "workspace:55.0.9",
    "@expo/vector-icons": "^15.0.2",
    "@ungap/structured-clone": "^1.3.0",
    "babel-preset-expo": "workspace:~55.0.8",
    "expo-asset": "workspace:~55.0.7",
    "expo-constants": "workspace:~55.0.7",
    "expo-file-system": "workspace:~55.0.9",
    "expo-font": "workspace:~55.0.4",
    "expo-keep-awake": "workspace:~55.0.4",
    "expo-modules-autolinking": "workspace:55.0.8",
    "expo-modules-core": "workspace:55.0.12",
    "pretty-format": "^29.7.0",
    "react-refresh": "^0.14.2",
    "whatwg-url-minimum": "^0.1.1"
  },
  "devDependencies": {
    "@expo/dom-webview": "workspace:*",
    "@expo/metro-runtime": "workspace:*",
    "@types/node": "^22.14.0",
    "@types/react": "~19.2.0",
    "expo-updates": "workspace:*",
    "npm-run-all2": "^8.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.2",
    "rimraf": "^6.1.2",
    "web-streams-polyfill": "^3.3.2"
  },
  "peerDependencies": {
    "@expo/dom-webview": "workspace:*",
    "@expo/metro-runtime": "workspace:*",
    "react": "*",
    "react-native": "*",
    "react-dom": "*",
    "react-native-web": "*",
    "react-native-webview": "*"
  },
  "peerDependenciesMeta": {
    "@expo/dom-webview": {
      "optional": true
    },
    "@expo/metro-runtime": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    },
    "react-native-webview": {
      "optional": true
    }
  }
}
